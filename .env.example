# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/masters_competition"

# Stats provider: "mock" | "espn" | "pga" (plug in your provider here)
MASTERS_STATS_PROVIDER="mock"

# Sync controls
SYNC_ENABLED="true"
SYNC_TIMEZONE="America/New_York"
SYNC_START_HOUR_ET="6"
SYNC_END_HOUR_ET="21"

# Admin page protection (simple shared secret)
ADMIN_SECRET="change-me-before-deploy"

# Commissioner master unlock code — used for post-lock edits and overrides
COMMISSIONER_CODE="1110"

# App URL (used for internal API calls from scheduled functions)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
